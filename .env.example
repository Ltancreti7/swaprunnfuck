# Database
DATABASE_URL=postgresql://user:password@host:5432/swaprunn

# Session (generate with: openssl rand -base64 32)
SESSION_SECRET=

# Email (Resend - https://resend.com)
RESEND_API_KEY=

# App URL (used in email links)
APP_URL=https://swaprunn.com

# Firebase Admin SDK (paste entire JSON as a single line)
FIREBASE_SERVICE_ACCOUNT=

# Backend URL used by the Capacitor iOS app for API calls (absolute URL required
# because the iOS bundle loads from capacitor://localhost, not the backend origin)
VITE_BACKEND_URL=https://swaprunn.com

# Cloudflare R2 object storage
# Account ID: Cloudflare Dashboard → right sidebar
R2_ACCOUNT_ID=
# Create an R2 API token with Object Read & Write permissions
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# The R2 bucket name you created
R2_BUCKET_NAME=swaprunn-uploads

# Node environment
NODE_ENV=production
